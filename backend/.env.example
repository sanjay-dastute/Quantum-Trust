# Environment Configuration for QuantumTrust Backend
# Copy this file to .env and replace the values with your actual configuration.

# Environment mode (production | staging | development)
NODE_ENV=development

# AES-256 master key for encrypting stored secrets (32-byte hex string)
MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# RS256 keys for JWT signing and verification (PEM-encoded)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# PostgreSQL connection string
DATABASE_URL=postgresql://quantum_admin:secure_password@localhost:5432/quantum_trust

# MongoDB connection string
MONGO_URI=mongodb://admin:secure_password@localhost:27017/quantum_trust?authSource=admin

# Redis connection string
REDIS_URL=redis://localhost:6379

# Comma-separated Kafka broker addresses
KAFKA_BROKERS=localhost:9092

# Path to Hyperledger Fabric network config
FABRIC_NETWORK_PATH=./fabric-network/

# SendGrid API key for email notifications
SENDGRID_API_KEY=SG.xxx

# Optional: PKCS#11 library path for Hardware Security Module (HSM)
HSM_LIBRARY_PATH=/usr/lib/libCryptoki2.so
